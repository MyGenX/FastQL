{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "FastQL",
  "description": "A Python-native GraphQL framework with a unified schema API and built-in execution engine.",
  "colors": {
    "primary": "#15803D",
    "light": "#22C55E",
    "dark": "#15803D"
  },
  "favicon": "/images/favicon.svg",
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg"
  },
  "appearance": {
    "default": "system"
  },
  "seo": {
    "metatags": {
      "canonical": "https://fastql.vachagan.dev"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Start",
        "pages": [
          "index",
          "start/introduction",
          "start/installation",
          "start/quickstart",
          "start/first-schema",
          "start/project-status",
          "start/faq"
        ]
      },
      {
        "group": "Build schemas",
        "pages": [
          "build/types-and-fields",
          "build/inputs-and-abstract-types",
          "build/operations-and-schema",
          "build/naming-and-configuration",
          "build/generic-types",
          "build/directives-and-visibility",
          "build/lazy-types"
        ]
      },
      {
        "group": "Resolve data",
        "pages": [
          "resolve/resolvers",
          "resolve/context-and-info",
          "resolve/dependencies",
          "resolve/extensions-and-permissions",
          "resolve/errors-and-nullability",
          "resolve/authentication"
        ]
      },
      {
        "group": "Data & performance",
        "pages": [
          "data/dataloader",
          "data/schema-extensions",
          "data/relay-pagination"
        ]
      },
      {
        "group": "Protocol features",
        "pages": [
          "protocol/subscriptions",
          "protocol/incremental-delivery",
          "protocol/uploads-and-batching"
        ]
      },
      {
        "group": "Federation",
        "pages": [
          "federation/overview",
          "federation/entities",
          "federation/custom-directives"
        ]
      },
      {
        "group": "Integrations",
        "pages": [
          "integrations/overview",
          "integrations/asgi-and-api-frameworks",
          "integrations/flask-and-django",
          "integrations/additional-frameworks",
          "integrations/context",
          "integrations/http-contract",
          "integrations/pydantic"
        ]
      },
      {
        "group": "Operations",
        "pages": [
          "operations/deployment",
          "operations/testing-and-export",
          "operations/observability"
        ]
      },
      {
        "group": "Tooling",
        "pages": [
          "tooling/dev-server",
          "tooling/cli",
          "tooling/schema-output"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "reference/overview",
          "reference/decorators",
          "reference/schema-and-execution",
          "reference/context",
          "reference/scalars-and-wrappers"
        ]
      },
      {
        "group": "Architecture",
        "pages": [
          "architecture/overview",
          "architecture/language-pipeline",
          "architecture/type-system",
          "architecture/validation-and-execution"
        ]
      },
      {
        "group": "Specifications",
        "pages": [
          "specifications/product-principles",
          "specifications/capability-catalog"
        ]
      },
      {
        "group": "Contribute",
        "pages": [
          "contribute/development",
          "contribute/documentation",
          "contribute/contributing"
        ]
      }
