    { "source": "/advanced/subscriptions", "destination": "/protocol/subscriptions" },
    { "source": "/advanced/incremental-delivery", "destination": "/protocol/incremental-delivery" },
    { "source": "/advanced/uploads-and-batching", "destination": "/protocol/uploads-and-batching" },
    { "source": "/advanced/federation", "destination": "/federation/overview" },
    { "source": "/advanced/generic-types", "destination": "/build/generic-types" },
    { "source": "/advanced/directives-and-visibility", "destination": "/build/directives-and-visibility" },
    { "source": "/advanced/pydantic", "destination": "/integrations/pydantic" },
    { "source": "/advanced/testing-and-export", "destination": "/operations/testing-and-export" },
    { "source": "/advanced/observability", "destination": "/operations/observability" }
